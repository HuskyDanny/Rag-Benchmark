# Shared Neo4j instance for local dev (see README "Shared Neo4j Instance").
# Namespacing is done via Graphiti group_id (benchmark_controlled/pipeline/presplit),
# so multiple projects can safely share this container.
NEO4J_URI=bolt://localhost:7690
NEO4J_USER=neo4j
NEO4J_PASSWORD=shared-dev-password
OPENAI_API_KEY=sk-...
